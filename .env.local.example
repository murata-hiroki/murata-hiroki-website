# LIFF「声を届ける」フォーム用の環境変数
# このファイルを .env.local にコピーして値を埋める（.env.local は git 管理外）
# Vercel にも同じ4つを設定すること

# ブラウザ露出OK（LIFF SDK 初期化に使用）
NEXT_PUBLIC_LIFF_ID=

# サーバー専用（IDトークン検証 / なりすまし防止）
LINE_LOGIN_CHANNEL_ID=

# サーバー専用（Supabase 書き込み）
SUPABASE_URL=
# サーバー専用・絶対にクライアントへ出さない
SUPABASE_SERVICE_ROLE_KEY=

# --- 声への返信 管理ページ（/admin/voices）用 ---
# 公式アカウント(Messaging API)チャネルの長期トークン。サーバー専用・秘密。
# ※ LIFFで使う LINE_LOGIN_CHANNEL_ID とは別物（Messaging API チャネルのトークン）
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# 管理画面 Basic 認証
ADMIN_USER=
ADMIN_PASSWORD=
